msgstr "Последняя публикация"

msgctxt "Languages::rlsv_autopost.edit_description"
msgid "Edit content"
msgstr "Редактировать контент"

msgctxt "Languages::rlsv_autopost.full_description"
msgid "Detailed description"
msgstr "Подробное описание"

msgctxt "Languages::rlsv_autopost.full_description_hint"
msgid "HTML is allowed (formatting, lists, links, images). Unsafe tags and scripts are removed automatically on save."
msgstr "Допустим HTML (форматирование, списки, ссылки, изображения). Небезопасные теги и скрипты автоматически удаляются при сохранении."

msgctxt "Languages::rlsv_autopost.open_product"
msgid "Open on storefront"
msgstr "Открыть на витрине"

msgctxt "Languages::rlsv_autopost.account_panel"
msgid "Autoposting"
msgstr "Автопостинг"

msgctxt "Languages::rlsv_autopost.account_panel_hint"
msgid "Manage your publishing API settings and view your publication analytics."
msgstr "Управляйте настройками API для публикаций и смотрите аналитику своих публикаций."

msgctxt "Languages::rlsv_autopost.bound_publishers"
msgid "Publishers of this product"
msgstr "Издатели этого товара"

msgctxt "Languages::rlsv_autopost.bound_publishers_hint"
msgid "Users selected here will autopost this product to their platforms (using their own API tokens)."
msgstr "Выбранные пользователи будут публиковать этот товар на свои площадки (используя свои токены API)."

msgctxt "SettingsSections::rlsv_autopost::instagram"
msgid "Instagram"
msgstr "Instagram"

msgctxt "SettingsOptions::rlsv_autopost::ig_media_feature_id"
msgid "Product feature ID for the post link"
msgstr "ID характеристики товара для ссылки на публикацию"

msgctxt "SettingsTooltips::rlsv_autopost::ig_media_feature_id"
msgid "Numeric ID of a text product feature where the module will store the published Instagram media link/ID. Leave empty to skip."
msgstr "Числовой ID текстовой характеристики товара, куда модуль запишет ссылку/ID опубликованного медиа Instagram. Оставьте пустым, чтобы не записывать."

msgctxt "SettingsOptions::rlsv_autopost::ig_fetch_insights"
msgid "Collect Instagram analytics (insights)"
msgstr "Собирать аналитику Instagram (insights)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_fetch_insights"
msgid "Enables the extended Instagram analytics page (feed/Reels/Stories). Requires a business/Creator account and instagram_manage_insights permission."
msgstr "Включает страницу расширенной аналитики Instagram (лента/Reels/Stories). Требуется бизнес/Creator-аккаунт и права instagram_manage_insights."

msgctxt "SettingsOptions::rlsv_autopost::ig_insights_limit"
msgid "Number of recent posts to analyze"
msgstr "Сколько последних публикаций анализировать"

msgctxt "SettingsTooltips::rlsv_autopost::ig_insights_limit"
msgid "How many recent feed/Reels posts to request insights for (1-50). Higher values load slower."
msgstr "Количество последних публикаций ленты/Reels, по которым запрашивать insights (1–50). Больше — медленнее загрузка страницы."

