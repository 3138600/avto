msgctxt "Languages::rlsv_autopost.ig_type_carousel"
msgid "Carousel"
msgstr "Карусель"

msgctxt "Languages::rlsv_autopost.ig_type_reels"
msgid "Reels"
msgstr "Reels"

msgctxt "Languages::rlsv_autopost.ig_type_story"
msgid "Story"
msgstr "История"

msgctxt "Languages::rlsv_autopost.ig_disabled"
msgid "Insights collection is disabled. Enable it in the module settings (Instagram tab)."
msgstr "Сбор insights отключён. Включите его в настройках модуля (вкладка Instagram)."

msgctxt "Languages::rlsv_autopost.ig_no_tokens"
msgid "Instagram tokens are not set. Fill them in settings:"
msgstr "Не заданы токены Instagram. Заполните их в настройках:"

msgctxt "Languages::rlsv_autopost.ig_api_error"
msgid "Failed to fetch data from the Instagram API"
msgstr "Не удалось получить данные из Instagram API"

msgctxt "Languages::rlsv_autopost.ig_no_metrics"
msgid "Metrics are unavailable (no insights permission, or the media is too new/old)."
msgstr "Метрики недоступны (нет прав insights, либо медиа слишком новое/старое)."

msgctxt "Languages::rlsv_autopost.ig_insights_note"
msgid "Data from the Instagram Graph API - for a business/Creator account with insights permission. Story stats are available for 24 hours only."
msgstr "Данные из Instagram Graph API — для бизнес/Creator-аккаунта с правами на insights. Статистика историй доступна только 24 часа."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_impressions"
msgid "Feature ID — Impressions"
msgstr "ID характеристики — Показы (Impressions)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_impressions"
msgid "Total number of times the post was shown on users' screens."
msgstr "Общее количество раз, когда публикация была показана на экранах пользователей."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_reach"
msgid "Feature ID — Reach"
msgstr "ID характеристики — Охват (Reach)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_reach"
msgid "Number of unique accounts that saw the post."
msgstr "Количество уникальных аккаунтов, которые увидели публикацию."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_engagement"
msgid "Feature ID — Engagement"
msgstr "ID характеристики — Вовлечённость (Engagement)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_engagement"
msgid "Total likes, comments and saves of the post."
msgstr "Общее количество лайков, комментариев и сохранений публикации."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_saved"
msgid "Feature ID — Saved (feed)"
msgstr "ID характеристики — Сохранения (Saved, лента)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_saved"
msgid "Number of users who saved the post to bookmarks."
msgstr "Количество пользователей, сохранивших публикацию в закладки."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_video_views"
msgid "Feature ID — Video Views"
msgstr "ID характеристики — Просмотры видео (Video Views)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_video_views"
msgid "Legacy video only: number of views longer than 3 seconds."
msgstr "Только для старых форматов видео: количество просмотров видео длительностью более 3 секунд."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_plays"
msgid "Feature ID — Plays (Reels)"
msgstr "ID характеристики — Воспроизведения (Plays, Reels)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_plays"
msgid "Reels: number of times the reel started (incl. autoplay and replays)."
msgstr "Reels: количество запусков ролика (включая автовоспроизведение и повторы)."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_total_interactions"
msgid "Feature ID — Total Interactions (Reels)"
msgstr "ID характеристики — Взаимодействия (Total Interactions, Reels)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_total_interactions"
msgid "Reels: total actions on the reel (likes, comments, saves, shares)."
msgstr "Reels: общее число действий с роликом (лайки, комментарии, сохранения, репосты)."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_likes"
msgid "Feature ID — Likes"
msgstr "ID характеристики — Лайки (Likes)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_likes"
msgid "Number of likes."
msgstr "Количество лайков."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_comments"
msgid "Feature ID — Comments"
msgstr "ID характеристики — Комментарии (Comments)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_comments"
msgid "Number of comments."
msgstr "Количество комментариев."

msgctxt "SettingsOptions::rlsv_autopost::ig_feature_saves"
msgid "Feature ID — Saves (Reels)"
msgstr "ID характеристики — Сохранения (Saves, Reels)"

msgctxt "SettingsTooltips::rlsv_autopost::ig_feature_saves"
