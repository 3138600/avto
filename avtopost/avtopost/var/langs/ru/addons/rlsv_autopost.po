msgstr "Очистить всю очередь"


msgctxt "SettingsOptions::rlsv_autopost::token_crypt_key"
msgid "Token encryption key"
msgstr "Ключ шифрования токенов"

msgctxt "SettingsTooltips::rlsv_autopost::token_crypt_key"
msgid "Secret key used to encrypt platform tokens at rest (AES-256). Set a long random string. If empty, a key is derived from install-specific values. Changing it makes previously saved tokens unreadable."
msgstr "Секрет для шифрования токенов площадок в БД (AES-256). Задайте длинную случайную строку. Если пусто — ключ выводится из install-специфичных значений. Смена ключа делает ранее сохранённые токены нечитаемыми."

msgctxt "Languages::rlsv_autopost.my_settings"
msgid "Autoposting: API settings"
msgstr "Автопостинг: настройки API"

msgctxt "Languages::rlsv_autopost.my_stats"
msgid "Autoposting: my analytics"
msgstr "Автопостинг: моя аналитика"

msgctxt "Languages::rlsv_autopost.settings_intro"
msgid "Fill in the tokens for the platforms you publish to. Fields are saved only for your account and stored encrypted."
msgstr "Заполните токены площадок, на которые публикуете контент. Поля сохраняются только в вашем профиле и хранятся в зашифрованном виде."

msgctxt "Languages::rlsv_autopost.settings_saved"
msgid "Settings saved"
msgstr "Настройки сохранены"

msgctxt "Languages::rlsv_autopost.product_saved"
msgid "Product content saved"
msgstr "Контент товара сохранён"

msgctxt "Languages::rlsv_autopost.csrf_failed"
msgid "Security check failed. Please reload the page and try again."
msgstr "Не пройдена проверка безопасности. Обновите страницу и попробуйте снова."

msgctxt "Languages::rlsv_autopost.proxy_invalid"
msgid "Proxy address is invalid and was not saved. Expected format: http://user:pass@host:port"
msgstr "Адрес прокси некорректен и не сохранён. Ожидаемый формат: http://user:pass@host:port"

