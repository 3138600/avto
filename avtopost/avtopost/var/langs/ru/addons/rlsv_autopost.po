msgstr "Прокси"

msgctxt "Languages::rlsv_autopost.proxy"
msgid "Proxy for publishing"
msgstr "Прокси для публикации"

msgctxt "Languages::rlsv_autopost.proxy_hint"
msgid "All outgoing requests for this administrator go through this proxy. Format: http://user:pass@host:port (socks5://… is also supported)."
msgstr "Все исходящие запросы этого администратора идут через указанный прокси. Формат: http://user:pass@host:port (поддерживается и socks5://…)."

