msgid "Publish products of this category"
msgstr "Публиковать товары этой категории"

msgctxt "Languages::rlsv_autopost.publish_category_hint"
msgid "Products of the marked category are added to the publication filter, in addition to the global target category."
msgstr "Товары отмеченной категории добавляются к фильтру публикации в дополнение к общей целевой категории."

msgctxt "Languages::rlsv_autopost.binding_legend"
