msgid "Autoposting"
msgstr "Автопостинг"

msgctxt "Languages::rlsv_autopost.tokens_hint"
msgid "Tokens are set individually per administrator and are used only for the target usergroup."
msgstr "Токены задаются индивидуально для каждого администратора и используются только для целевой группы."

