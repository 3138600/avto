msgctxt "Addons::name::rlsv_autopost"
msgid "RLSV Autopost"
msgstr "RLSV — Автопостинг недвижимости"

msgctxt "Addons::description::rlsv_autopost"
msgid "Cross-posting of commercial real estate listings to 8 platforms (PUSH) and 3 XML feeds (PULL). Queue + cron, per-administrator tokens, logging via core event log."
msgstr "Кросс-постинг карточек коммерческой недвижимости на 8 площадок (PUSH) и 3 XML-фида (PULL). Очередь и крон, токены в профиле администратора, логирование через журнал событий ядра."

msgctxt "SettingsSections::rlsv_autopost::general"
msgid "General"
msgstr "Общие настройки"

msgctxt "SettingsSections::rlsv_autopost::platforms"
msgid "Active platforms (PUSH)"
msgstr "Активные площадки (PUSH)"

msgctxt "SettingsOptions::rlsv_autopost::target_category_id"
msgid "Target category ID"
msgstr "ID целевой категории (фильтр публикации)"

msgctxt "SettingsTooltips::rlsv_autopost::target_category_id"
msgid "Only products linked to this category are published. Leave empty to disable the filter."
msgstr "Публикуются только товары, привязанные к этой категории. Оставьте пустым, чтобы отключить фильтр."

msgctxt "SettingsOptions::rlsv_autopost::target_usergroup_id"
msgid "Target usergroup ID"
msgstr "ID группы пользователей-издателей"

msgctxt "SettingsTooltips::rlsv_autopost::target_usergroup_id"
msgid "Only administrators from this usergroup are used as token sources. Leave empty for all administrators."
msgstr "Автопостом занимаются ОБЫЧНЫЕ пользователи (не обязательно администраторы), состоящие в этой группе, — используются их токены. Укажите ID группы (Покупатели → Группы пользователей). Если поле пустое, публикуют только пользователи, явно привязанные к товару или категории."

msgctxt "SettingsOptions::rlsv_autopost::video_object_feature_id"
msgid "Video feature ID"
msgstr "ID характеристики товара с URL видеопрезентации (YouTube/RuTube)"

msgctxt "SettingsTooltips::rlsv_autopost::video_object_feature_id"
msgid "Product feature that stores the video URL used for YouTube and RuTube uploads."
msgstr "Характеристика товара, в которой хранится URL видео для загрузки на YouTube и RuTube."

msgctxt "SettingsOptions::rlsv_autopost::post_delay_minutes"
msgid "Publish delay, minutes"
msgstr "Задержка публикации, минут (0 = сразу по крону)"

msgctxt "SettingsOptions::rlsv_autopost::cron_batch_size"
msgid "Cron batch size"
msgstr "Размер пачки крона (задач за один проход)"

msgctxt "SettingsOptions::rlsv_autopost::cron_password"
msgid "Cron password"
msgstr "Пароль крона (защита dispatch=rlsv_oauth.cron)"

msgctxt "SettingsTooltips::rlsv_autopost::cron_password"
msgid "Required to run the queue: index.php?dispatch=rlsv_oauth.cron&cron_password=..."
msgstr "Обязателен для запуска очереди: index.php?dispatch=rlsv_oauth.cron&cron_password=..."

msgctxt "SettingsOptions::rlsv_autopost::feed_secret"
msgid "Feed secret"
msgstr "Секрет для доступа к XML-фидам (необязательно)"

